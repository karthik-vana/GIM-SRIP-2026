# pyenv
#   For a library or package, you might want to share your Python version with the development team
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not install
#   dependencies that should be installed.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact versions of dependencies that were installed
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact versions of dependencies that were installed
# pdm.lock

# virtualenv
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

